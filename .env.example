# Google Books API key, used in stage 01 for publication-year and metadata lookups.
# Obtain one from the Google Cloud console and paste it here, then copy this file to .env
GOOGLE_BOOKS_API_KEY=your-key-here

# Google Cloud Vision credentials, used in stage 02 for OCR of book preview screenshots.
# Path to a service-account JSON key file on your machine.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/vision-service-account.json
